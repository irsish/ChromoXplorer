# =============================================================================
# ChromoXplorer — Environment Configuration
# =============================================================================
# Copy this file to .env, fill in your values, then run:
#   docker compose up --build -d
#
# LOCAL DEV vs UBUNTU SERVER — only these values differ:
#
#   Variable            Local dev               Ubuntu server
#   ──────────────────────────────────────────────────────────
#   NODE_ENV            development             production
#   VITE_API_BASE_URL   http://localhost:3000   http://<server-ip>:3000
#   CORS_ORIGIN         http://localhost:5173   http://<server-ip>:5173
#
# Everything else (Mongo credentials, Cognito) stays the same.
# =============================================================================

# ---------------------------------------------------------------------------
# Environment
# ---------------------------------------------------------------------------
# development → enables verbose logging in Express
# production  → disables dev-only behaviour
NODE_ENV=development

# ---------------------------------------------------------------------------
# MongoDB — admin credentials (creates the root user on first container start)
# ---------------------------------------------------------------------------
# Use this to connect MongoDB Compass:
#   mongodb://MONGO_ROOT_USERNAME:MONGO_ROOT_PASSWORD@localhost:27017/?authSource=admin
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=your_strong_admin_password

# ---------------------------------------------------------------------------
# MongoDB — backend service credentials (readWrite on chromoxplorer db only)
# ---------------------------------------------------------------------------
# Created automatically by mongo-init.js on first container start.
MONGO_BACKEND_USER=chromox_backend
MONGO_BACKEND_PASSWORD=your_strong_backend_password

# ---------------------------------------------------------------------------
# MongoDB URI  (must match MONGO_BACKEND_USER / MONGO_BACKEND_PASSWORD above)
# ---------------------------------------------------------------------------
MONGODB_URI=mongodb://chromox_backend:your_strong_backend_password@mongodb:27017/chromoxplorer?authSource=chromoxplorer

# ---------------------------------------------------------------------------
# Backend CORS — comma-separated list of origins the API will accept
# ---------------------------------------------------------------------------
# Local:  http://localhost
# Server: http://localhost,http://<server-ip>
CORS_ORIGIN=http://localhost

# ---------------------------------------------------------------------------
# Frontend — URL the browser uses to reach the backend API
# ---------------------------------------------------------------------------
# Local:  http://localhost:3000
# Server: http://<server-ip>:3000
# NOTE: changing this requires rebuilding the frontend image (docker compose up --build)
VITE_API_BASE_URL=http://localhost:3000
VITE_SITE_URL=https://chromoxplorer.org
VITE_GOOGLE_SITE_VERIFICATION=
VITE_SUPPORT_EMAIL=support@chromoxplorer.com

# ---------------------------------------------------------------------------
# AWS Cognito
# ---------------------------------------------------------------------------
# Authority URL format: https://cognito-idp.<region>.amazonaws.com/<user-pool-id>
VITE_COGNITO_AUTHORITY=https://cognito-idp.us-east-1.amazonaws.com/YOUR_USER_POOL_ID

# App Client ID from your Cognito User Pool
VITE_COGNITO_CLIENT_ID=YOUR_APP_CLIENT_ID

# Cognito Hosted UI domain (used for logout redirect)
# Format: https://<your-domain-prefix>.auth.<region>.amazoncognito.com
VITE_COGNITO_DOMAIN=https://YOUR_DOMAIN_PREFIX.auth.us-east-1.amazoncognito.com

# Backend JWT verification (same issuer + client as frontend; used for /admin routes)
# Option A — full issuer URL:
COGNITO_ISSUER=https://cognito-idp.us-east-1.amazonaws.com/YOUR_USER_POOL_ID
# Option B — omit COGNITO_ISSUER and set pool id + region (Docker/backend will derive issuer):
# COGNITO_REGION=us-east-1
# COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
# Optional: Cognito group name that grants admin (default: admin)
# COGNITO_ADMIN_GROUP=admin
COGNITO_CLIENT_ID=YOUR_APP_CLIENT_ID

# ---------------------------------------------------------------------------
# AWS S3
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_ACCESS_KEY
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=YOUR_BUCKET_NAME
AWS_S3_BUCKET_URL=https://YOUR_BUCKET_NAME.s3.YOUR_REGION.amazonaws.com
